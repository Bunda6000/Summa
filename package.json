{
  "name": "budget-planner",
  "version": "1.0.0",
  "description": "Personal budget planner – track expenses, incomes, and spending trends",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:init": "npx cap init \"Budget Planner\" com.budgetplanner.app --web-dir dist",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:build": "vite build && npx cap sync",
    "deploy": "vite build && npx cap sync && npx cap open android",
    "postinstall": "node patch-capacitor.js"
  },
  "dependencies": {
    "@capacitor/app": "6.0.2",
    "@capacitor/core": "6.2.0",
    "@capacitor/preferences": "6.0.3",
    "@capacitor/splash-screen": "6.0.3",
    "@capacitor/status-bar": "6.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.15.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/cli": "^8.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "^5.6.3",
    "vite": "^8.0.1"
  }
}
